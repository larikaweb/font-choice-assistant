# Cloud LLM
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1-mini
OPENAI_API_KEY=

# Optional local mode through an Ollama OpenAI-compatible endpoint
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3:8b
OLLAMA_API_KEY=ollama

# Google Fonts metadata lookup
GOOGLE_FONTS_API_KEY=

# Demo defaults
LLM_MOCK_MODE=true
DEFAULT_LANGUAGE=ru
